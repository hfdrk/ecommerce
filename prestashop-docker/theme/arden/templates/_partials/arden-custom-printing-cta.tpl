{**
 * “Need Custom Printing Done Right?” — live-site headline band.
 *}
<section class="arden-custom-printing" aria-labelledby="arden-custom-printing-title">
  <div class="arden-custom-printing__inner">
    <div class="arden-custom-printing__copy">
      <h2 id="arden-custom-printing-title" class="arden-display arden-custom-printing__title">{l s='Need custom printing done right?' d='Shop.Theme.Global'}</h2>
      <p class="arden-custom-printing__lead">
        {l s='From DTF transfers to full print-on-demand services — we’ve got you covered with top quality, fast turnaround, and no minimums.' d='Shop.Theme.Global'}
      </p>
    </div>
    <div class="arden-custom-printing__actions">
      <a class="arden-btn arden-btn--primary" href="{$arden_shop|default:$urls['pages']['new_products']}">{l s='Get started' d='Shop.Theme.Global'}</a>
      <a class="arden-btn arden-btn--outline arden-custom-printing__outline" href="{$arden_contact|default:$urls['pages']['contact']}">{l s='Talk to us' d='Shop.Theme.Global'}</a>
    </div>
  </div>
</section>
