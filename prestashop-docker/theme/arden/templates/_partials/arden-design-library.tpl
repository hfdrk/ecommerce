{**
 * "Browse Design Library" — CTA banner matching ardensprint.com.
 *}
<section class="arden-design-library" aria-labelledby="arden-design-library-title">
  <div class="arden-design-library__inner">
    <div class="arden-design-library__content">
      <p class="arden-section-eyebrow">{l s='Design Library' d='Shop.Theme.Global'}</p>
      <h2 id="arden-design-library-title" class="arden-display arden-design-library__title">{l s='Thousands of ready-to-print designs' d='Shop.Theme.Global'}</h2>
      <p class="arden-design-library__lead">{l s='Browse our curated library of professional graphics — search by style, theme, or trending category. Customize any design and order in minutes.' d='Shop.Theme.Global'}</p>
      <div class="arden-design-library__tags">
        <span class="arden-lib-tag">Sports</span>
        <span class="arden-lib-tag">Vintage</span>
        <span class="arden-lib-tag">Holidays</span>
        <span class="arden-lib-tag">Typography</span>
        <span class="arden-lib-tag">Animals</span>
        <span class="arden-lib-tag">Patriotic</span>
        <span class="arden-lib-tag">Floral</span>
        <span class="arden-lib-tag">Faith</span>
      </div>
      <a class="arden-btn arden-btn--primary" href="{$arden_cms.design_library|default:$urls['pages']['contact']}">{l s='Browse Design Library' d='Shop.Theme.Global'}</a>
    </div>
  </div>
</section>
