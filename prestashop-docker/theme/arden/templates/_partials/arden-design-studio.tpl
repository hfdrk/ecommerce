<section class="arden-design-block" aria-labelledby="arden-design-title">
  <div class="arden-design-block__inner">
  <div class="arden-design-block__grid">
    <div class="arden-design-block__main">
      <p class="arden-eyebrow">Design tools</p>
      <h2 id="arden-design-title" class="arden-display">Create mockups before you commit</h2>
      <ol class="arden-design-steps">
        <li>Go to <strong>ardensprint.com</strong> → Design Studio</li>
        <li>Create your design</li>
        <li>Place your order</li>
      </ol>
      <div class="arden-design-actions">
        <a class="arden-btn arden-btn--primary" href="{$arden_cms.design_studio|default:$urls['pages']['contact']}">Design Studio</a>
        <a class="arden-btn arden-btn--ghost" href="{$arden_cms.design_library|default:$urls['pages']['contact']}">Design Library</a>
      </div>
    </div>
    <div class="arden-design-block__aside">
      <p class="arden-design-block__aside-title">What you can do</p>
      <ul class="arden-design-list">
        <li>Upload artwork — logo or image — or use a design library</li>
        <li>Preview on mockups for tees, hoodies, totes &amp; more</li>
        <li>Great for schools, fundraisers, businesses, events</li>
      </ul>
    </div>
  </div>
  </div>
</section>
