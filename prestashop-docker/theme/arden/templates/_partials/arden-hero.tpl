{**
 * Hero — print-on-demand first: clear offer, how it works, proof row.
 *}
<section class="arden-hero arden-hero--pod" aria-labelledby="arden-hero-title">
  <div class="arden-hero__bg" aria-hidden="true"></div>
  <div class="arden-hero__inner">
    <div class="arden-hero__copy">
      <p class="arden-eyebrow">Order online · Production to order · Ship to you or your customer</p>
      <h1 id="arden-hero-title" class="arden-display">Custom printed products — <span class="arden-hero__shine">buy what you need, when you need it.</span></h1>
      <p class="arden-lead">
        Shop blanks, DTF, and add-ons with no warehouse to fill: we produce to order with clear pricing so you can sell or decorate with confidence.
      </p>
      <ul class="arden-hero__pill-row" aria-label="Why buy from us">
        <li class="arden-hero__pill">Secure checkout</li>
        <li class="arden-hero__pill">Clear production windows</li>
        <li class="arden-hero__pill">Support from real people</li>
      </ul>
      <div class="arden-hero__actions">
        <a class="arden-btn arden-btn--primary" href="{$arden_shop|default:$urls['pages']['new_products']}">Shop the catalog</a>
        <a class="arden-btn arden-btn--ghost" href="{$arden_cms.design_studio|default:$urls['pages']['contact']}">Design tools</a>
        <a class="arden-btn arden-btn--outline" href="{$arden_contact|default:$urls['pages']['contact']}">Questions? Contact us</a>
      </div>
      <p class="arden-hero__micro">Browse anytime · Cart saves your line · Volume programs available</p>
    </div>

    <div class="arden-hero__pod-panel">
      <h2 class="arden-hero__panel-title">How print on demand works</h2>
      <ol class="arden-hero__pod-steps">
        <li>
          <span class="arden-hero__step-num">1</span>
          <span class="arden-hero__step-body">
            <strong>Pick products &amp; artwork</strong>
            <span>Choose blanks or transfers, upload art, or use our design tools.</span>
          </span>
        </li>
        <li>
          <span class="arden-hero__step-num">2</span>
          <span class="arden-hero__step-body">
            <strong>We print &amp; finish</strong>
            <span>DTF, gang sheets, or decorated apparel — produced to order.</span>
          </span>
        </li>
        <li>
          <span class="arden-hero__step-num">3</span>
          <span class="arden-hero__step-body">
            <strong>Ship where you need</strong>
            <span>To your shop, your event, or dropship to your end customer.</span>
          </span>
        </li>
      </ol>
      <p class="arden-hero__panel-foot">Wholesale blanks and rush options — ask our team for programs that fit your volume.</p>
    </div>

    <dl class="arden-hero__facts">
      <div class="arden-fact">
        <dt class="arden-fact__k">Model</dt>
        <dd class="arden-fact__v">Print on demand</dd>
      </div>
      <div class="arden-fact">
        <dt class="arden-fact__k">Inventory</dt>
        <dd class="arden-fact__v">You don’t stock our catalog</dd>
      </div>
      <div class="arden-fact">
        <dt class="arden-fact__k">Turnaround</dt>
        <dd class="arden-fact__v">Fast production windows</dd>
      </div>
      <div class="arden-fact arden-fact--accent">
        <dt class="arden-fact__k">Support</dt>
        <dd class="arden-fact__v">Real people, real answers</dd>
      </div>
    </dl>
  </div>
</section>
