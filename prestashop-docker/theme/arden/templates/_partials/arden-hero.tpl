{**
 * Hero v3 — cinematic + scroll reveal + particle texture.
 *}
<section class="arden-hero" aria-labelledby="arden-hero-title">
  <div class="arden-hero__bg" aria-hidden="true"></div>
  <div class="arden-hero__overlay arden-hero__overlay--lr" aria-hidden="true"></div>
  <div class="arden-hero__overlay arden-hero__overlay--bt" aria-hidden="true"></div>
  <div class="arden-hero__inner">
    <div class="arden-hero__copy">
      <p class="arden-eyebrow arden-reveal">DTF Transfers · Blank Apparel · Print on Demand</p>
      <h1 id="arden-hero-title" class="arden-display arden-reveal arden-reveal-d1">Production-grade printing,<br>zero minimums.</h1>
      <p class="arden-lead arden-reveal arden-reveal-d2">
        Consistent color, fast turnarounds, and apparel sourced for
        decorators who care about the details.
      </p>
      <div class="arden-hero__actions arden-reveal arden-reveal-d3">
        <a class="arden-btn arden-btn--white" href="{$arden_shop|default:$urls['pages']['new_products']}">Browse catalog</a>
        <a class="arden-btn arden-btn--outline-white" href="{$arden_contact|default:$urls['pages']['contact']}">Talk to production</a>
      </div>
    </div>

    <dl class="arden-hero__facts arden-reveal arden-reveal-d4">
      <div class="arden-fact">
        <dd class="arden-fact__v">24h</dd>
        <dt class="arden-fact__k">Typical DTF turn</dt>
      </div>
      <div class="arden-fact">
        <dd class="arden-fact__v">$0</dd>
        <dt class="arden-fact__k">Order minimum</dt>
      </div>
      <div class="arden-fact">
        <dd class="arden-fact__v">POD</dd>
        <dt class="arden-fact__k">Fulfillment ready</dt>
      </div>
    </dl>
  </div>
</section>
