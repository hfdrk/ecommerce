<section class="arden-membership" aria-labelledby="arden-membership-title">
  <div class="arden-membership__inner">
    <p class="arden-membership__eyebrow">Save more as you grow</p>
    <h2 id="arden-membership-title" class="arden-display">Knight of Savings</h2>
    <p class="arden-membership__intro">Membership tiers with discounts on eligible orders — details and signup on <a href="https://ardensprint.com/">ardensprint.com</a>.</p>
    <div class="arden-membership__tiers">
      <div class="arden-tier">
        <p class="arden-tier__name">Warrior</p>
        <p class="arden-tier__price">$14.99<span>/month</span></p>
        <ul class="arden-tier__feats">
          <li>Member pricing on select catalog</li>
          <li>Early access to promos</li>
        </ul>
      </div>
      <div class="arden-tier">
        <p class="arden-tier__name">Elite</p>
        <p class="arden-tier__price">$39.99<span>/month</span></p>
        <ul class="arden-tier__feats">
          <li>Higher discounts &amp; perks</li>
          <li>Priority production queue</li>
        </ul>
      </div>
      <div class="arden-tier">
        <p class="arden-tier__name">Royal</p>
        <p class="arden-tier__price">$89.99<span>/month</span></p>
        <ul class="arden-tier__feats">
          <li>Best rates for high volume</li>
          <li>Dedicated account support</li>
        </ul>
      </div>
    </div>
    <a class="arden-btn arden-btn--primary" href="{$arden_cms.membership|default:$urls['pages']['contact']}">View membership details</a>
  </div>
</section>
