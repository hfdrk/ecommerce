{**
 * Membership — professional pricing tiers with expanded feature lists.
 *}
<section class="arden-membership" aria-labelledby="arden-membership-title">
  <div class="arden-membership__inner">
    <p class="arden-membership__eyebrow">Membership</p>
    <h2 id="arden-membership-title" class="arden-display">Predictable savings for production shops</h2>
    <p class="arden-membership__intro">Unlock tiered discounts when you print often. Cancel any time — no contracts. Signup on <a href="https://ardensprint.com/">ardensprint.com</a>.</p>
    <div class="arden-membership__tiers">
      <div class="arden-tier">
        <p class="arden-tier__name">Warrior</p>
        <p class="arden-tier__price">$14.99<span>/month</span></p>
        <ul class="arden-tier__feats">
          <li>5% off all catalog orders</li>
          <li>Priority order processing</li>
          <li>Member-only color library</li>
          <li>Standard support</li>
        </ul>
      </div>
      <div class="arden-tier">
        <p class="arden-tier__name">Elite</p>
        <p class="arden-tier__price">$39.99<span>/month</span></p>
        <ul class="arden-tier__feats">
          <li>12% off all catalog orders</li>
          <li>Rush production queue</li>
          <li>Quarterly sample box</li>
          <li>Dedicated account rep</li>
          <li>Custom gang sheet templates</li>
        </ul>
      </div>
      <div class="arden-tier">
        <p class="arden-tier__name">Royal</p>
        <p class="arden-tier__price">$89.99<span>/month</span></p>
        <ul class="arden-tier__feats">
          <li>18% off all catalog orders</li>
          <li>Same-day DTF production</li>
          <li>White-label fulfillment</li>
          <li>Custom routing rules</li>
          <li>1-on-1 onboarding call</li>
          <li>Volume pricing unlocked</li>
        </ul>
      </div>
    </div>
    <a class="arden-btn arden-btn--primary" href="{$arden_cms.membership|default:$urls['pages']['contact']}">Request access</a>
  </div>
</section>
